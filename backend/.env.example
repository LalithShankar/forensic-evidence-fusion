# Copy to .env for local development. Never commit .env.
APP_ENV=local
APP_NAME=forensic-evidence-fusion
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Local-only placeholders (no real secrets)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/forensic_dev
SECRET_KEY=change-me-in-local-env-only
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Deployed-only (ignored when APP_ENV=local)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
