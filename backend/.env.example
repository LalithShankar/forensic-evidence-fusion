# Copy to .env for local development. Never commit .env.
APP_ENV=local
APP_NAME=forensic-evidence-fusion
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Local-only placeholders (no real secrets)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/forensic_dev
SECRET_KEY=change-me-in-local-env-only
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATA_ROOT=./data

# Optional local Azurite / Azure Storage emulator (when set, local mode uses blob backend)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=...;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_STORAGE_CONTAINER=forensic-evidence

# Deployed-only (ignored when APP_ENV=local)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
# AZURE_STORAGE_CONNECTION_STRING loaded from env / Key Vault in deployed mode

# Azure AI Search (deployed; local/CI uses in-memory mock when unset)
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_INDEX=forensic-evidence
# AZURE_SEARCH_API_KEY=

# Azure OpenAI (deployed; local/CI uses mock LLM when unset)
# AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
